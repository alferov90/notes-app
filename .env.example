SECRET_KEY=change-me-use-openssl-rand-hex-32
POSTGRES_PASSWORD=change-me-strong-password

# Telegram-бот для напоминаний (создайте через @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_BOT_USERNAME=YourNoteFlowBot

# Часовой пояс для напоминаний (если время приходит без UTC-метки)
APP_TIMEZONE=Europe/Moscow

# Прокси для api.telegram.org (если сервер не достучится напрямую)
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
# TELEGRAM_PROXY_URL=http://proxy.example.com:8080
